{
  "$defs": {
    "DataStatus": {
      "enum": [
        "observed",
        "reanalysis",
        "reported",
        "modeled",
        "mixed",
        "synthetic_fixture",
        "synthetic_demo",
        "algorithmic_result",
        "scenario_model"
      ],
      "title": "DataStatus",
      "type": "string"
    },
    "MultiPolygonGeometry": {
      "additionalProperties": false,
      "properties": {
        "coordinates": {
          "items": {
            "items": {
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "type": "array"
          },
          "minItems": 1,
          "title": "Coordinates",
          "type": "array"
        },
        "type": {
          "const": "MultiPolygon",
          "default": "MultiPolygon",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "coordinates"
      ],
      "title": "MultiPolygonGeometry",
      "type": "object"
    },
    "PolygonGeometry": {
      "additionalProperties": false,
      "properties": {
        "coordinates": {
          "items": {
            "items": {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            "type": "array"
          },
          "minItems": 1,
          "title": "Coordinates",
          "type": "array"
        },
        "type": {
          "const": "Polygon",
          "default": "Polygon",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "coordinates"
      ],
      "title": "PolygonGeometry",
      "type": "object"
    },
    "TaiwanZoneFeature": {
      "additionalProperties": false,
      "properties": {
        "geometry": {
          "discriminator": {
            "mapping": {
              "MultiPolygon": "#/$defs/MultiPolygonGeometry",
              "Polygon": "#/$defs/PolygonGeometry"
            },
            "propertyName": "type"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PolygonGeometry"
            },
            {
              "$ref": "#/$defs/MultiPolygonGeometry"
            }
          ],
          "title": "Geometry"
        },
        "id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "properties": {
          "$ref": "#/$defs/TaiwanZoneProperties"
        },
        "type": {
          "const": "Feature",
          "default": "Feature",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "geometry",
        "properties"
      ],
      "title": "TaiwanZoneFeature",
      "type": "object"
    },
    "TaiwanZoneProperties": {
      "additionalProperties": false,
      "properties": {
        "area_km2": {
          "exclusiveMinimum": 0,
          "title": "Area Km2",
          "type": "number"
        },
        "centroid_lat": {
          "maximum": 27,
          "minimum": 21,
          "title": "Centroid Lat",
          "type": "number"
        },
        "centroid_lon": {
          "maximum": 123,
          "minimum": 118,
          "title": "Centroid Lon",
          "type": "number"
        },
        "county_code": {
          "maxLength": 20,
          "minLength": 1,
          "title": "County Code",
          "type": "string"
        },
        "data_status": {
          "$ref": "#/$defs/DataStatus"
        },
        "name_zh": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Name Zh",
          "type": "string"
        },
        "population": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Population"
        },
        "population_year": {
          "anyOf": [
            {
              "maximum": 2200,
              "minimum": 1900,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Population Year"
        },
        "source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Source Ids",
          "type": "array"
        },
        "town_code": {
          "anyOf": [
            {
              "maxLength": 20,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Town Code"
        },
        "zone_id": {
          "maxLength": 120,
          "minLength": 1,
          "title": "Zone Id",
          "type": "string"
        }
      },
      "required": [
        "zone_id",
        "county_code",
        "name_zh",
        "area_km2",
        "centroid_lon",
        "centroid_lat",
        "data_status"
      ],
      "title": "TaiwanZoneProperties",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "data_status": {
      "$ref": "#/$defs/DataStatus"
    },
    "features": {
      "items": {
        "$ref": "#/$defs/TaiwanZoneFeature"
      },
      "title": "Features",
      "type": "array"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Ids",
      "type": "array"
    },
    "type": {
      "const": "FeatureCollection",
      "default": "FeatureCollection",
      "title": "Type",
      "type": "string"
    }
  },
  "required": [
    "data_status",
    "features"
  ],
  "title": "TaiwanZoneCollection",
  "type": "object"
}
