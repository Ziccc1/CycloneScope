{
  "$defs": {
    "DataStatus": {
      "enum": [
        "observed",
        "reanalysis",
        "reported",
        "modeled",
        "mixed",
        "synthetic_fixture",
        "synthetic_demo",
        "algorithmic_result",
        "scenario_model"
      ],
      "title": "DataStatus",
      "type": "string"
    },
    "TrackPoint": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "anyOf": [
            {
              "maxLength": 20,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Category"
        },
        "is_landfall": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Is Landfall"
        },
        "lat": {
          "maximum": 90,
          "minimum": -90,
          "title": "Lat",
          "type": "number"
        },
        "lon": {
          "maximum": 180,
          "minimum": -180,
          "title": "Lon",
          "type": "number"
        },
        "moving_speed_kmh": {
          "anyOf": [
            {
              "maximum": 400,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Moving Speed Kmh"
        },
        "pressure_hpa": {
          "anyOf": [
            {
              "maximum": 1100,
              "minimum": 800,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Pressure Hpa"
        },
        "source_agency": {
          "anyOf": [
            {
              "maxLength": 80,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Agency"
        },
        "storm_status": {
          "anyOf": [
            {
              "maxLength": 40,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Storm Status"
        },
        "time": {
          "format": "date-time",
          "title": "Time",
          "type": "string"
        },
        "wind_ms": {
          "anyOf": [
            {
              "maximum": 150,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wind Ms"
        }
      },
      "required": [
        "time",
        "lon",
        "lat"
      ],
      "title": "TrackPoint",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "data_status": {
      "$ref": "#/$defs/DataStatus"
    },
    "generated_at": {
      "format": "date-time",
      "title": "Generated At",
      "type": "string"
    },
    "points": {
      "items": {
        "$ref": "#/$defs/TrackPoint"
      },
      "minItems": 1,
      "title": "Points",
      "type": "array"
    },
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_ids": {
      "items": {
        "type": "string"
      },
      "title": "Source Ids",
      "type": "array"
    },
    "storm_id": {
      "maxLength": 40,
      "minLength": 1,
      "title": "Storm Id",
      "type": "string"
    }
  },
  "required": [
    "data_status",
    "storm_id",
    "points"
  ],
  "title": "StormTrackResponse",
  "type": "object"
}
