{
  "schema_version": "1.0",
  "data_version": "a8-final-2026.07.19",
  "purpose": "single handoff manifest for B/C; do not discover files manually",
  "run_order": [
    "download_sources.py",
    "process_ibtracs_real.py",
    "derive_a2_metrics.py",
    "select_classic_storms_revised.py",
    "prepare_era5_requests.py",
    "download_era5.py",
    "qa_era5_batch.py",
    "process_worldpop.py",
    "derive_taiwan_hazard.py",
    "derive_taiwan_hazard_time.py",
    "normalize_taiwan_boundaries.py",
    "normalize_taiwan_stat_population.py",
    "join_statistical_boundaries_population.py",
    "normalize_shelters.py",
    "normalize_a6_interface.py",
    "merge_facilities.py",
    "build_official_road_network.py",
    "calculate_network_service_area.py",
    "derive_a7_features.py",
    "normalize_reported_impact.py",
    "normalize_tce_dat.py",
    "prepare_frontend_assets.py",
    "a8_final_audit.py",
    "upgrade_audit.py"
  ],
  "canonical_scripts_dir": "pipeline/",
  "historical_scripts_dir": "pipeline/archive/",
  "frontend_derivatives": {
    "admin_overview": "output/processed/frontend/taiwan-admin-overview.geojson",
    "statistical_zones_simplified": "output/processed/frontend/statistical-zones-simplified.geojson",
    "era5_capability": "output/processed/frontend/era5-frontend-capability.json",
    "similarity_eligibility": "output/processed/frontend/similarity-eligibility.json"
  },
  "handoff_datasets": {
    "tracks_global": "output/processed/ibtracs-global-since1980",
    "tracks_wp": "output/processed/ibtracs-wp-since1980",
    "classic_cases": "output/processed/classic/classic-storms.json",
    "era5_capability": "output/processed/era5/qa/era5-capability-matrix.json",
    "reported_impact": "output/processed/impact/reported/reported-impact.parquet",
    "tce_dat": "output/processed/impact/tce-dat/tce-dat-exposure.parquet",
    "official_population": "output/processed/taiwan/population/statistical-zones-population-official.parquet",
    "statistical_boundaries": "output/processed/taiwan/population/statistical-zones.geojson",
    "facilities": "output/processed/taiwan/facilities/facilities-all.geojson",
    "road_nodes": "output/processed/taiwan/roads/nodes.parquet",
    "road_edges": "output/processed/taiwan/roads/edges.parquet",
    "service_area": "output/processed/taiwan/roads/facility-service-area.parquet",
    "a7_features": "output/processed/features"
  },
  "ui_rules": {
    "era5": "read allowed_modes; hide animation if unavailable",
    "similarity": "exclude ids in similarity-eligibility.json",
    "population": "show population_reference and population_match_status",
    "roads": "show speed_source and travel_time_quality",
    "impact": "keep reported_impact and modeled_exposure separate"
  },
  "validation": "python pipeline/a8_final_audit.py && python pipeline/upgrade_audit.py",
  "not_in_git": [
    "input/raw/",
    "output/processed/large data files",
    "NetCDF",
    "GeoTIFF",
    "PBF",
    "large Parquet"
  ]
}