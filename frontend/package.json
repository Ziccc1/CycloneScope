{
  "name": "cyclonescope-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "generate:types": "openapi-typescript ../schemas/generated/openapi.json -o src/types/api.generated.ts",
    "build": "npm run generate:types && tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
